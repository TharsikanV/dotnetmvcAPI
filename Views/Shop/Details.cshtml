@{
    ViewData["Title"] = "Shop Details";
}
<h1 class="text-3xl font-bold mb-4">Shop Details</h1>
<div class="bg-white rounded-lg shadow p-6">
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Location:</strong> @Model.Location</p>
    <p><strong>Category:</strong> @Model.Category</p>
    <p><strong>Manager Name:</strong> @Model.Manager_Name</p>
    <p><strong>Description:</strong> @Model.Description</p>
    <a asp-controller="Shop" asp-action="Edit" asp-route-id="@Model.Id"
       class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition mt-2 inline-block">
        Edit
    </a>
</div>

