@{
    ViewData["Title"] = "Home";
}

<section class="flex flex-col items-center justify-center min-h-[80vh] text-center px-6">
    <h1 class="text-6xl font-extrabold text-slate-900 mb-6">
        Shop Management System
    </h1>

    <p class="text-xl text-slate-600 max-w-3xl mb-8">
        Manage shops, items, and orders efficiently with ASP.NET Core MVC.
    </p>

    <div class="flex gap-4">
        <a asp-controller="Shop"
           asp-action="Index"
           class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition">
            View Shops
        </a>

        <a asp-controller="Items"
           asp-action="Index"
           class="border border-gray-300 px-6 py-3 rounded-lg hover:bg-gray-100 transition">
            View Items
        </a>
    </div>
</section>