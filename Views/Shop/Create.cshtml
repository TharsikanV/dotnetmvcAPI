@model MyMvcApp.Models.Shop

<h1>Create Shop</h1>

<form class="flex flex-col gap-4" asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly"></div>
    <div class="flex flex-col gap-2">
        <div class="flex gap-1">
        <label>Name</label>
        <input class="border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" asp-for="Name" />
        </div>
        <span class="text-danger" asp-validation-for="Name"></span>
    </div>
    <div class="flex flex-col gap-2">
        <div class="flex gap-1">
            <label>Location</label>
            <input class="border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" asp-for="Location" />
        </div>
        <span class="text-danger" asp-validation-for="Location"></span>
    </div>

    <div class="flex flex-col gap-2">
        <div class="flex gap-1">
        <label>Category</label>
        <select class="border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" asp-for="Category">
            <option value="">-- Select Category --</option>
            <option value="Electronics">Electronics</option>
            <option value="Clothing">Clothing</option>
            <option value="Food">Food</option>
            <option value="Books">Books</option>
            <option value="Furniture">Furniture</option>
        </select>
        </div>
        <span class="text-danger" asp-validation-for="Category"></span>
    </div>

    <div class="flex flex-col gap-2">
        <div class="flex gap-1">
            <label>Manager Name</label>
            <input class="border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" asp-for="Manager_Name" />
        </div>
        <span class="text-danger" asp-validation-for="Manager_Name"></span>
    </div>

    <div class="flex flex-col gap-2">
        <div class="flex gap-1">
            <label>Description</label>
            <textarea class="border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500" asp-for="Description"></textarea>
        </div>
        <span class="text-danger" asp-validation-for="Description"></span>
    </div>

    <button class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded w-fit" type="submit">Save</button>
</form>